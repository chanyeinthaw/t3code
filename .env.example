# Optional: Pulse Connect source builds
# Leave these unset to disable optional Pulse Connect features in local source builds.
# Release builds inject their public values at build time. Do not add server-side
# secrets to this file.

# Get these from the Clerk Dashboard under API keys, JWT templates, and OAuth applications.
# PULSE_CLERK_PUBLISHABLE_KEY=pk_test_...
# PULSE_CLERK_JWT_TEMPLATE=pulse-relay
# PULSE_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...

# Optional: signed macOS passkey builds. The RP domain defaults to the Frontend API
# hostname encoded in PULSE_CLERK_PUBLISHABLE_KEY. Set the override only when Clerk
# returns a different RP ID or when multiple domains must be entitled.
# PULSE_APPLE_TEAM_ID=ABC1234567
# PULSE_MACOS_PROVISIONING_PROFILE=/absolute/path/to/pulse.provisionprofile
# PULSE_CLERK_PASSKEY_RP_DOMAINS=example.clerk.accounts.dev,clerk.example.com

# Get this from your relay deployment. `infra/relay` deploys update it automatically.
# PULSE_RELAY_URL=https://relay.example.com

# Public, ingest-only mobile OpenTelemetry configuration.
# PULSE_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# PULSE_MOBILE_OTLP_TRACES_DATASET=pulse-mobile-traces-dev
# PULSE_MOBILE_OTLP_TRACES_TOKEN=xaat-...
